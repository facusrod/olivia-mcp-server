# Odoo Connection
ODOO_URL=http://localhost:8069
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=

# API Key para autenticación del MCP Server (requerida en modo HTTP)
# Generá una con: node -e "console.log(crypto.randomUUID())"
MCP_API_KEY=

# Puerto del servidor HTTP
MCP_PORT=3001

